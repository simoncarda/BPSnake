@using BPSnake.Components.GamePageComponents
@using BPSnake.Models
@using BPSnake.Configuration

@page "/"
@implements IDisposable

@* Hlavní směrovač (Router) pohledů. 
  Místo navigace na různé URL adresy dynamicky měníme vykreslené komponenty na jedné stránce 
  na základě aktuálního stavu hry (State Machine). Typický přístup pro Single Page Aplikace (SPA). 
*@
@switch (_engine.CurrentGameState)
{
    case GameState.Menu:
        <StartMenuScreen OnStartNewGame="@StartNewGame" />
        break;

    case GameState.Playing:
    case GameState.Paused:
        @* Předáváme delegáty (EventCallbacks) pro komunikaci dceřiné komponenty s rodičem *@
        <GameBoardScreen OnPauseGame="@PauseGameAsync"
                         OnResumeGame="@ResumeGameAsync"
                         HandleKeyboardInput="@HandleInput" />

        @* Vykreslení UI na základě detekce zařízení (skryto na desktopu) *@
        if (_showTouchControls) {
            <TouchControls />
        }
        break;
    case GameState.GameOver:
        <GameOverScreen OnStartNewGame="@StartNewGame" />
        break;
}