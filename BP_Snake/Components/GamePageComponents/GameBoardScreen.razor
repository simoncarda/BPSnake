@using BPSnake.Models;
@using BPSnake.Models.GameCore;

@inject IGameEngine Engine
@* Nutné pro zavolání metody Dispose() a prevenci memory leaku *@
@implements IDisposable

<div class="game-container">
    <div class="game-header">
        @if (Engine.CurrentGameState == GameState.Playing) {
            <button type="button" class="btn btn-info" @onclick="OnPauseGame">Pause</button>
        } else if (Engine.CurrentGameState == GameState.Paused) {
            <button type="button" class="btn btn-info" @onclick="HandleResumeClick">Resume</button>
        }
    </div>

    @* tabindex="0" a @ref jsou nezbytné pro zachycení klávesnice *@
    <div class="gameboard" style="grid-template-columns: repeat(@Engine.CurrentGameBoard.Width, 1fr); grid-template-rows: repeat(@Engine.CurrentGameBoard.Height, 1fr);" tabindex="0" @ref="_boardElement">
        @for (int y = 0; y < Engine.CurrentGameBoard.Height; y++) {
            @for (int x = 0; x < Engine.CurrentGameBoard.Width; x++) {
                <div class="@Engine.GetCellCssClass(x, y)"></div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public EventCallback OnPauseGame { get; set; }
    [Parameter] public EventCallback OnResumeGame { get; set; }
    [Parameter] public EventCallback<KeyboardEventArgs> HandleKeyboardInput { get; set; }

    private ElementReference _boardElement;

    /// <summary>
    /// Řeší kliknutí na tlačítko "Resume". Po obnovení hry z pauzy je nutné vrátit focus
    /// zpět na herní plochu, jinak by uživatel musel znovu kliknout myší pro funkčnost klávesnice.
    /// </summary>
    private async Task HandleResumeClick()
    {
        await OnResumeGame.InvokeAsync();
        await _boardElement.FocusAsync();
    }

    private async Task HandleInput(KeyboardEventArgs e)
    {
        await HandleKeyboardInput.InvokeAsync(e);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) {
            // Automatický focus pro okamžité ovládání z klávesnice bez klikání myší
            await _boardElement.FocusAsync();
        }
    }

    protected override void OnInitialized()
    {
        Engine.OnStateChangedAsync += RefreshUIAsync;
    }

    // InvokeAsync je nutné, protože event z enginu může přijít z jiného (než UI) vlákna
    private Task RefreshUIAsync() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        if (Engine != null) {
            Engine.OnStateChangedAsync -= RefreshUIAsync;
        }
    }
}