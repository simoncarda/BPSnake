@using BPSnake.Models.DataLayer;
@using BPSnake.Services;
@inject IDatabaseService DbService
@implements IDisposable

<div>
    @if (!_highScores.Any()) {
        <p>Zatím žádné záznamy.</p>
    } else {
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th colspan="5">
                            <h4>Highscores</h4>
                        </th>
                    </tr>
                </thead>
                <thead>
                    <tr>
                        <th>Pozice</th>
                        <th>Jméno</th>
                        <th>Skóre</th>
                        <th>Level</th>
                        <th>Datum</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int position = 1;
                    }
                    @foreach (var item in _highScores) {
                        <tr>
                            <td>@(position)</td>
                            <td><strong>@item.PlayerName</strong></td>
                            <td>@item.Score</td>
                            <td>@item.TotalLevelsCompleted</td>
                            <td>@item.DateTimeAchieved.ToString("dd.MM.yyyy HH:mm")</td>
                        </tr>
                        position++;
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<GameScore> _highScores = new();

    protected override async Task OnInitializedAsync()
    {
        // Prvotní načtení dat
        _highScores = await DbService.GetScoresAsync();
        // Přihlášení k odběru události pro reaktivní aktualizaci tabulky
        DbService.ScoresChanged += OnScoresChanged;
    }

    private async void OnScoresChanged()
    {
        _highScores = await DbService.GetScoresAsync();
        // Překreslení je nutné vynutit ručně, protože událost přišla ze služby na pozadí
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        // Odhlášení odběru brání únikům paměti (memory leaks) při zničení komponenty
        DbService.ScoresChanged -= OnScoresChanged;
    }
}
